    {
        "id_lesson": "basic_ope_3",
        "pages": [
            {
                "blocks": [
                    {
                        "type": "title",
                        "text": "Signos de agrupación"
                    },
                    {
                        "type": "card_example",
                        "content": [
                            {
                                "type": "short_example",
                                "text": "1) + (y) = + y"
                            },
                            {
                                "type": "short_example",
                                "text": "1) + (-y) = - y"
                            },
                            {
                                "type": "large_example",
                                "text": "1) + (y) = + y"
                            },
                            {
                                "type": "large_example",
                                "text": "1) + (-y) = - y"
                            },
                            {
                                "type": "large_example",
                                "text": "Regla 1: Cuando un número o variable tiene un + delante del paréntesis, simplemente eliminamos los paréntesis."
                            }
                        ]
                    },
                    {
                        "type": "body",
                        "text": "Ordena el signo donde corresponda"
                    },
                    {
                        "type": "input_exercise",
                        "text": "+ (3x) = "
                    }
                ]
            },
            {
                "blocks": [
                    {
                        "type": "title",
                        "text": "Ordena las cartas según la expresión equivalente a:"
                    },
                    {
                        "type": "card_drag_dynamic",
                        "list_cards": ["x - y", "-x + y", "-x - y"],
                        "list_questions": ["+ (x - y) =", "+ (-x + y) =", "+ (-x - y) ="]
                    }
                ]
            },
            {
                "blocks": [
                    {
                        "type": "title",
                        "text": "Resuelve lo siguiente"
                    },
                    {
                        "type": "input_exercise",
                        "text": "(2a + a) + (2b - c)"
                    }
                ]
            },
            {
                "blocks": [
                    {
                        "type": "title",
                        "text": "Resuelve lo siguiente"
                    },
                    {
                        "type": "card_dynamic",
                        "list": ["2x + (-c) =", "2cx", "2(x-c)", "2x", "2c", "2x - c"]
                    }
                ]
            },
            {
                "blocks": [
                    {
                        "type": "title",
                        "text": "Signos de agrupación"
                    },
                    {
                        "type": "card_example",
                        "content": [
                            {
                                "type": "short_example",
                                "text": "1) - (y) = - y"
                            },
                            {
                                "type": "short_example",
                                "text": "2) - (-y) = + y"
                            },
                            {
                                "type": "large_example",
                                "text": "1) - (y) = - y"
                            },
                            {
                                "type": "large_example",
                                "text": "2) - (-y) = + y"
                            },
                            {
                                "type": "large_example",
                                "text": "Regla 2: Si hay un - (negativo) delante del paréntesis, cambiamos el signo de cada cantidad dentro del paréntesis por su inverso."
                            }
                        ]
                    },
                    {
                        "type": "body",
                        "text": "Resuelve lo siguiente"
                    },
                    {
                        "type": "input_exercise",
                        "text": "- (3x) = "
