                            {
                                "type": "large_example",
                                "text": "= (3x - 2)  (-2x -+8)"
                            },
                            {
                                "type": "large_example",
                                "text": "= (3x - 2)x - (8 - 2)"
                            },
                            {
                                "type": "large_example",
                                "text": "(x) + (6)"
                            },
                            {
                                "type": "large_example",
                                "text": "x + 6"
                            },
                            {
                                "type": "large_example",
                                "text": "- Se eliminan paréntesis negativo cambiando los signos del segundo binomio."
                            },
                            {
                                "type": "large_example",
                                "text": "- Se agrupan términos semejantes: los que tienen \"x\" y los números"
