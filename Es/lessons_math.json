                                "type": "large_example",
                                "text": "Propiedad distributiva"
                            },
                            {
                                "type": "large_example",
                                "text": "Multiplicamos el número c por cada término dentro del paréntesis"
                            },
                            {
                                "type": "large_example",
                                "text": "c(a) = ac"
                            },
                            {
                                "type": "large_example",
                                "text": "c(-b) = -bc"
                            },
                            {
                                "type": "large_example",
                                "text": "Así, el resultado es:"
                            },
                            {
                                "type": "large_example",
                                "text": "ac - bc"
