            "blocks": [
                {
                    "type": "title",
                    "text": "Método por igualación"
                },
                {
                    "type": "linear_system",
                    "equationOne": "-2x - y = 6    ...1",
                    "equationTwo": "-2x - 2y = 2   ...2"
                },
                {
                    "type": "body",
                    "text": "Despejando \"y\" de 1:",
                },
                {
                    "type": "body",
                    "text": "-y = 2x + 6",
                    "isMathText": true
                },
                {
                    "type": "body",
                    "text": "y = -2x - 6",
                    "isMathText": true
                },
                {
                    "type": "body",
                    "text": "Despejando \"y\" de 2:",
                },
                {
                    "type": "body",
                    "text": "y = - (2x + 2) / 2",
                    "isMathText": true
                },
                {
                    "type": "body",
                    "text": "y = x - 1",
                    "isMathText": true
                },
                {
                    "type": "body",
                    "text": "Igualando los resultados y hallando x:",
                },
                {
                    "type": "body",
                    "text": "-2x - 6 = x - 1",
                    "isMathText": true
                },
                {
                    "type": "body",
                    "text": "-2x - x = 6 - 1",
                    "isMathText": true
                },
                {
                    "type": "body",
                    "text": "x = -5",
                    "isMathText": true
                },
                {
                    "type": "body",
                    "text": "Sustituyendo x = -5 en 1:",
                },
                {
                    "type": "body",
                    "text": "y = 4",
                    "isMathText": true
                },
                {
                    "type": "body",
                    "text": "...(x, y) = (-5, 4)",
                    "isMathText": true
                }
            ]
        },
        {
            "blocks": [
                {
                    "type": "title",
                    "text": "Paso 1. Despejan \"y\" de la ecuación 1."
