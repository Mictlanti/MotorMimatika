{
    "id_lesson": "law_exp_1",
    "pages": [
        {
            "blocks": [
                {
                    "type": "title",
                    "text": "Productos de potencia de igual base"
                },
                {
                    "type": "body",
                    "text": "Un exponente o potencia no es más que una cantidad multiplicada por sí misma un número determinado de veces."
                },
                {
                    "type": "body",
                    "text": "Primera ley:"
                },
                {
                    "type": "card_example",
                    "content": [
                        {
                            "type": "large_exponent",
                            "base": ["a", "* a", "= a"],
                            "power": ["m", "n", "m + n"]
                        },
                        {
                            "type": "large_example",
                            "text": "Cuando tenemos dos exponentes con la misma base, el exponente resultante es la suma de los exponentes de los factores dados."
                        }
                    ]
                }
            ]
        },
        {
            "blocks": [
                {
                    "type": "title",
                    "text": "Ejemplo de desarrollo"
                },
                {
                    "type": "large_exponent",
                    "base": ["a", "* a", "= a", "= a"],
                    "power": ["2", "3", "2 + 3", "5"]
                },
                {
                    "type": "title",
                    "text": "Simplifica las siguientes expresiones"
                },
                {
                    "type": "card_dynamic",
                    "list": ["a * a^4 =", "a^6", "a^5", "a^4", "a", "a^3"]
                }
            ]
