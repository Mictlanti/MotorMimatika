{
    "id_lesson": "point_plane_1",
    "pages": [
        {
            "blocks": [
                {
                    "type": "title",
                    "text": "Par ordenado"
                },
                {
                    "type": "body",
                    "text": "Es un conjunto de dos números que representan un orden:"
                },
                {
                    "type": "body",
                    "text": "(a ,b)",
                    "isMathText": true
                },
                {
                    "type": "body",
                    "text": "- El primero \"a\", indica la posición en el eje horizontal (x) en un plano."
                },
                {
                    "type": "body",
                    "text": "- El segundo \"b\", indica la posición en el eje vertical (y) en un plano."
                },
                {
                    "type": "title",
                    "text": "¿Cuál de los siguiente representa un par ordenado?"
                },
                {
                    "type": "button_exercise",
                    "list": ["ac, bd", "(a + b)", "(32)b", "(3, 2)"]
                }
            ]
        },
        {
            "blocks": [
                {
                    "type": "title",
                    "text": "Punto de origen"
                },
                {
                    "type": "body",
                    "text": "Representado por el par ordenado:"
                },
                {
                    "type": "body",
                    "text": "(0, 0)",
                    "isMathText": true
                },
                {
                    "type": "body",
                    "text": "Es la intersección de los ejes \"x\" y \"y\""
                },
                {
                    "type": "body",
                    "text": "Gráficamente:"
                },
                {
                    "type": "cartesian_plane",
                    "pointX": [0.0],
                    "pointY": [0.0]
                }
            ]
        },
        {
            "blocks": [
                {
                    "type": "body",
                    "text": "El par ordenado "
                },
                {
                    "type": "body",
                    "text": "(2, 3)",
                    "isMathText": true
                },
                {
                    "type": "body",
                    "text": "significa que, con respecto al punto de origen:"
                },
                {
                    "type": "body",
                    "text": "- Avanza dos pasos a la derecha (en x).",
                    "isMathText": true
                },
                {
                    "type": "body",
                    "text": "- Luego sube 3 pasos hacia arriba (en y)",
                    "isMathText": true
                },
                {
                    "type": "body",
                    "text": "Gráficamente:"
                },
                {
                    "type": "cartesian_plane",
                    "pointX": [2.0],
                    "pointY": [3.0]
                }
            ]
        },
        {
            "blocks": [
                {
                    "type": "title",
                    "text": "¿Qué implica el siguiente par ordenado?"
                },
                {
                    "type": "body",
                    "text": "(4, 1)",
                    "isMathText": true
                },
                {
                    "type": "button_exercise",
                    "list": [
                        "- x avanza 4 pasos a la derecha\n- y avanza 1 paso hacia arriba",
                        "- x avanza 1 paso hacia arriba\n- y avanza 4 pasos a la derecha"
                    ],
                    "isVerticalExercise": true
                }
            ]
        },
        {
            "blocks": [
                {
                    "type": "title",
                    "text": "Plano cartesiano"
                },
                {
                    "type": "body",
                    "text": "El eje x en el plano se representa de forma:"
                },
                {
                    "type": "button_exercise",
                    "list": ["horizontal", "vertical", "inclinada", "ninguna"],
                }
            ]
        }
    ]
}
