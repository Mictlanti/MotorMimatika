        {
            "blocks": [
                {
                    "type": "title",
                    "text": "Cociente de potencias de igual base"
                },
                {
                    "type": "card_example",
                    "content": [
                        {
                            "type": "large_exponent",
                            "base": ["a", " / a", "= a"],
                            "power": ["m", "n", "m - n"]
                        },
                        {
                            "type": "large_example",
                            "text": "Cuando tenemos dos exponentes con la misma base, el exponente resultante es la resta de los exponentes de los factores dados."
                        }
                    ]
                },
                {
                    "type": "body",
                    "text": "Simplifica la siguiente expresión."
                },
                {
                    "type": "card_dynamic",
                    "list": ["y^9 / y^3 =", "y^6", "y^8", "y^1", "y^3", "y^4"]
                }
            ]
        },
        {
            "blocks": [
                {
                    "type": "body",
                    "text": "Simplifica la siguiente expresión."
                },
                {
                    "type": "card_dynamic",
                    "list": ["(x^2 / x^3) * x =", "x^5", "x^2", "x", "x^3", "x^4"]
                }
            ]
        },
        {
            "blocks": [
