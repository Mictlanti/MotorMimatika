                        {
                            "type": "short_example",
                            "text": "(a + b)(a - b) = a^2 - b^2"
                        },
                        {
                            "type": "large_example",
                            "text": "El producto de una suma por su resta da como resultado la diferencia de los cuadrados de los términos."
                        },
                        {
                            "type": "large_example",
                            "text": "Paso a paso:"
                        },
                        {
                            "type": "large_example",
                            "text": "- Al multiplicar obtenemos:"
                        },
                        {
                            "type": "large_example",
                            "text": "a^2 - ab + ab - b^2"
                        },
                        {
                            "type": "large_example",
                            "text": "- Restamos: ab - ab = 0"
                        },
                        {
                            "type": "large_example",
                            "text": "... (a + b)(a - b) = a^2 - b^2"
                        }
