{
    "id_lesson": "facto_3_1",
    "pages": [
        {
            "blocks": [
                {
                    "type": "title",
                    "text": "Contesta lo siguiente"
                },
                {
                    "type": "input_exercise",
                    "text": "(2x + 1)(x + 3) ="
                }
            ]
        },
        {
            "blocks": [
                {
                    "type": "body",
                    "text": "En productos notables vimos la fórmula:"
                },
                {
                    "type": "body",
                    "text": "(ax+b)(cx+d) = acx^2+(ad+bc)x+bd",
                    "isMathText": true,
                    "fontSizeMath": 15
                },
                {
                    "type": "title",
                    "text": "De la ecuación:"
                },
                {
                    "type": "body",
                    "text": "(2x + 5)(3x - 3)",
                    "isMathText": true
                },
                {
                    "type": "body",
                    "text": "Aplicando la fórmula:"
                },
                {
                    "type": "body",
                    "text": "ac = 2*3",
                    "isMathText": true
                },
                {
                    "type": "body",
                    "text": "ad + bc = 2*-3 + 5*3",
                    "isMathText": true
                },
                {
                    "type": "button_exercise",
                    "list": ["bd = 5*-3", "bd = 5*3"]
                }
            ]
        },
        {
            "blocks": [
                {
                    "type": "body",
                    "text": "Formula:"
                },
                {
                    "type": "body",
                    "text": "(ax+b)(cx+d) = acx^2+(ad+bc)x+bd",
                    "isMathText": true,
                    "fontSizeMath": 15
                },
                {
                    "type": "title",
                    "text": "De la ecuación:"
                },
                {
                    "type": "body",
                    "text": "(2x + 4)(2x + 6)",
                    "isMathText": true
                },
                {
                    "type": "body",
                    "text": "Aplicando la fórmula:"
                },
                {
                    "type": "body",
                    "text": "ad + bc = 2*6 + 4*2",
                    "isMathText": true
                },
                {
                    "type": "body",
                    "text": "bd = 4*6",
                    "isMathText": true
                },
                {
                    "type": "button_exercise",
                    "list": ["ac = 2*2", "ac = 2*4"]
                }
            ]
        },
        {
            "blocks": [
                {
                    "type": "body",
                    "text": "Formula:"
                },
                {
                    "type": "body",
                    "text": "(ax+b)(cx+d) = acx^2+(ad+bc)x+bd",
                    "isMathText": true,
                    "fontSizeMath": 15
                },
                {
                    "type": "title",
                    "text": "De la ecuación:"
                },
                {
                    "type": "body",
                    "text": "(3x + 2)(x + 1)",
                    "isMathText": true
                },
                {
                    "type": "body",
                    "text": "Aplicando la fórmula:"
                },
                {
                    "type": "body",
                    "text": "ac = 3*1",
                    "isMathText": true
                },
                {
                    "type": "body",
                    "text": "bd = 2*1",
                    "isMathText": true
                },
                {
                    "type": "button_exercise",
                    "list": ["ad+bc = 3*2+1*1", "ad+bc = 3*1+2*1"],
                    "isVerticalExercise": true
                }
            ]
        },
        {
            "blocks": [
                {
                    "type": "title",
                    "text": "En factorización, aplicaremos la formula a la inversa:"
                },
                {
                    "type": "card_example",
                    "content": [
                        {
                            "type": "short_example",
                            "text": "(ax+b)(cx+d) = acx^2+(ad+bc)x+bd",
                            "fontSize": 15
                        },
                        {
                            "type": "large_example",
                            "text": "Cuadrado del término común, más la suma de productos cruzados, más producto de las constantes."
                        },
                        {
                            "type": "large_example",
                            "text": "Paso a paso:"
                        },
                        {
                            "type": "large_example",
                            "text": "- Producto de los primeros términos."
                        },
                        {
                            "type": "large_example",
                            "text": "a * c * x^2 = acx^2"
                        },
                        {
                            "type": "large_example",
                            "text": "- Multiplica cruzado y suma:"
                        },
                        {
                            "type": "large_example",
                            "text": "a * d * x + b * c * x = (ad + bc)x"
                        },
                        {
                            "type": "large_example",
                            "text": "- Multiplica los términos constantes"
                        },
                        {
                            "type": "large_example",
                            "text": "b * d = bd"
                        }
                    ]
                },
                {
                    "type": "body",
                    "text": "Aplicando la fórmula"
                },
                {
                    "type": "ab_second_exercise",
                    "options": ["a", "b"],
                    "equation": "3x^2 + 5x + 2 = "
                }
            ]
        }
    ]
}
