        {
            "blocks": [
                {
                    "type": "title",
                    "text": "Producto de binomios con término común"
                },
                {
                    "type": "card_example",
                    "content": [
                        {
                            "type": "short_example",
                            "text": "(ax+b)(cx+d) = acx^2+(ad+bc)x+bd"
                        },
                        {
                            "type": "short_example",
                            "text": "Cuadrado del término común, más la suma de productos cruzados, más producto de las constantes."
                        },
                        {
                            "type": "large_example",
                            "text": "Paso a paso:"
                        },
                        {
                            "type": "large_example",
                            "text": "- Producto de los primeros términos."
                        },
                        {
                            "type": "large_example",
                            "text": "a * c * x^2 = acx^2"
                        },
                        {
                            "type": "large_example",
                            "text": "- Multiplica cruzado y suma:"
                        },
                        {
                            "type": "large_example",
                            "text": "a * d * x + b * c * x = (ad + bc)x"
                        },
                        {
                            "type": "large_example",
                            "text": "- Multiplica los términos constantes"
                        },
                        {
                            "type": "large_example",
                            "text": "b * d = bd"
                        }
                    ]
                },
                {
                    "type": "body",
                    "text": "Ejemplo."
                },
                {
                    "type": "body",
                    "text": "(2x + 1)(x + 3)",
                    "isMathText": true
                },
                {
                    "type": "body",
                    "text": "= 2*1*x^2 + (2*3 + 1*1)x + 1 * 3",
                    "isMathText": true
                },
                {
                    "type": "body",
                    "text": "= 2x^2 + 6x + 3",
                    "isMathText": true
                }
            ]
        },
