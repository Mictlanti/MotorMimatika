    "pages": [
        {
            "blocks": [
                {
                    "type": "title",
                    "text": "Suma de monomios"
                },
                {
                    "type": "card_example",
                    "content": [
                        {
                            "type": "short_example",
                            "text": "Un monomio es una expresión algebraica que tiene un solo término, donde las únicas operaciones entre variables son el producto y la potencia de exponentes naturales."
                        },
                        {
                            "type": "large_example",
                            "text": "Ejemplo:"
                        },
                        {
                            "type": "large_example",
                            "text": "4x"
                        },
                        {
                            "type": "large_example",
                            "text": "-5x^6"
                        },
                        {
                            "type": "large_example",
                            "text": "2x^2y"
                        },
                        {
                            "type": "large_example",
                            "text": "-20x^8y^3z^6"
                        }
                    ]
                },
                {
                    "type": "body",
                    "text": "¿Cuál de los siguientes es un monomio?"
                },
                {
                    "type": "button_exercise",
                    "list": ["2", "2x + 1", "-3t^2y", "x(r + t)"]
                }
            ]
        },
        {
            "blocks": [
                {
                    "type": "title",
                    "text": "Multiplicación de binomios"
                },
                {
                    "type": "card_example",
                    "content": [
                        {
                            "type": "short_example",
                            "text": "(a + b)(x + y) = a(x + y) + b(x + y)"
                        },
                        {
                            "type": "short_example",
                            "text": "= ax + ay + bx + by"
                        },
                        {
                            "type": "large_example",
                            "text": "- Se aplica la propiedad distributiva:"
                        },
                        {
                            "type": "large_example",
                            "text": "a(x + y) = ax + ay"
                        },
                        {
                            "type": "large_example",
                            "text": "b(x + y) = bx + by"
                        },
                        {
                            "type": "large_example",
                            "text": "Se suman los resultados:"
                        },
                        {
                            "type": "large_example",
                            "text": "ax + ay + bx + by"
                        }
                    ]
                },
                {
                    "type": "body",
                    "text": "Aplica la propiedad distributiva para \"a\""
                },
                {
                    "type": "input_exercise",
                    "text": "a(x - y) ="
                }
            ]
        },
